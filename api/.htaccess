# ===========================================================
# SÉCURITÉ - Bloquer accès HTTP direct aux fichiers sensibles
# ===========================================================

# Protection directe Apache (sans dépendance à mod_rewrite)
<FilesMatch "^\.env(\..+)?$">
    Require all denied
</FilesMatch>

<FilesMatch "^\.git">
    Require all denied
</FilesMatch>

<FilesMatch "^\.htaccess$">
    Require all denied
</FilesMatch>

# =================================
# ROUTING - Redirige vers index.php
# =================================
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloquer les fichiers sensibles
    RewriteRule ^\.env - [F,L]
    RewriteRule ^\.env\. - [F,L]
    RewriteRule ^\.htaccess$ - [F,L]
    RewriteRule ^\.git - [F,L]

    # Rediriger vers index.php SEULEMENT si ce n'est pas un fichier/dossier réel
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>